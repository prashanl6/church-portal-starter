# Database
DATABASE_URL="file:./prisma/dev.db"

# JWT Secret
JWT_SECRET="your-secret-key-here"

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=prashan.bastiansz@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=prashan.bastiansz@gmail.com
FROM_NAME=Church Portal

# Base URL for email links
NEXT_PUBLIC_BASE_URL=http://localhost:3001
BASE_URL=http://localhost:3001

# Cron: booking auto-cancel (set in production; Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# IANA timezone for hall booking start times (payment deadline = start − 1 hour in this zone)
BOOKING_TIMEZONE=Asia/Colombo
