generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  email                String     @unique
  passwordHash         String
  role                 String     @default("guest") // admin, staff, guest
  status               String     @default("active")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  approvalsAsApprover1 Approval[] @relation("Approver1")
  approvalsAsApprover2 Approval[] @relation("Approver2")
}

model Approval {
  id           Int      @id @default(autoincrement())
  resourceType String
  resourceId   Int
  action       String
  submitterId  Int
  approver1Id  Int?
  approver2Id  Int?
  status       String   @default("SUBMITTED") // SUBMITTED, APPROVED, REJECTED
  comment1     String?
  comment2     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approver1 User? @relation("Approver1", fields: [approver1Id], references: [id])
  approver2 User? @relation("Approver2", fields: [approver2Id], references: [id])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorId      Int
  action       String
  theme        String?
  resourceType String
  resourceId   Int
  beforeJson   String?
  afterJson    String?
  status       String   @default("draft")
  userAgent    String?
  createdAt    DateTime @default(now())
}

model Asset {
  id            Int      @id @default(autoincrement())
  reference     String
  value         Float
  quantity      Int
  labelCategory String
  notes         String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PeopleEvent {
  id         Int      @id @default(autoincrement())
  personName String
  type       String // birthday, wedding_anniversary
  date       DateTime
  status     String   @default("active") // active, inactive
  email      String?
  phone      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  bodyHtml  String
  weekOf    DateTime
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sermon {
  id        Int       @id @default(autoincrement())
  title     String
  speaker   String
  date      DateTime
  dateOnly  DateTime
  link      String
  views     Int       @default(0)
  rating    Int       @default(0)
  status    String    @default("published")
  tagsJson  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([dateOnly])
}

model ProcessDoc {
  id          Int      @id @default(autoincrement())
  title       String
  ownerUserId Int
  contentHtml String
  version     Int      @default(1)
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id            Int      @id @default(autoincrement())
  bookingRef    String   @unique
  hall          String
  date          DateTime
  startTime     String
  endTime       String
  purpose       String
  requesterName String
  email         String
  phone         String
  status        String   @default("REQUESTED")
  paymentRef    String?
  amount        Float?
  slipUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MedicalItem {
  id                Int           @id @default(autoincrement())
  name              String
  quantityTotal     Int
  quantityAvailable Int
  notes             String?
  loans             MedicalLoan[]
}

model MedicalLoan {
  id                Int       @id @default(autoincrement())
  itemId            Int
  givenTo           String
  givenByUserId     Int
  requestDate       DateTime  @default(now())
  approvedByAdminId Int?
  approvedAt        DateTime?
  issuedAt          DateTime?
  dueDate           DateTime?
  returned          Boolean   @default(false)
  returnedAt        DateTime?
  conditionOnReturn String?

  item MedicalItem @relation(fields: [itemId], references: [id])
}

model Upload {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  path        String
  fileName    String
  mimeType    String
  sizeBytes   Int
  checksum    String?
  createdAt   DateTime @default(now())
}
