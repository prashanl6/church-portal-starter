generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  email                String     @unique
  passwordHash         String
  role                 String     @default("guest") // admin, staff, guest
  status               String     @default("active")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  approvalsAsApprover1 Approval[] @relation("Approver1")
  approvalsAsApprover2 Approval[] @relation("Approver2")
  auditLogs            AuditLog[]
}

model Approval {
  id           Int      @id @default(autoincrement())
  resourceType String
  resourceId   Int
  action       String
  submitterId  Int
  approver1Id  Int?
  approver2Id  Int?
  status       String   @default("SUBMITTED") // SUBMITTED, APPROVED, REJECTED
  comment1     String?
  comment2     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approver1 User? @relation("Approver1", fields: [approver1Id], references: [id])
  approver2 User? @relation("Approver2", fields: [approver2Id], references: [id])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorId      Int
  action       String
  theme        String?
  resourceType String
  resourceId   Int
  beforeJson   String?
  afterJson    String?
  status       String   @default("draft")
  userAgent    String?
  createdAt    DateTime @default(now())
  
  actor User @relation(fields: [actorId], references: [id])
}

model Asset {
  id            Int      @id @default(autoincrement())
  reference     String
  value         Float
  quantity      Int
  labelCategory String
  notes         String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// People tracked for birthdays (and linkable as partners on anniversaries).
model ChurchIndividual {
  id           Int       @id @default(autoincrement())
  displayName  String
  birthDate    DateTime? // required for new individuals in API; optional for legacy placeholders
  email        String?
  phone        String?
  notes        String?
  dateOfDeath  DateTime?
  status       String    @default("active") // active, inactive
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  anniversariesAsA WeddingAnniversary[] @relation("AnniversaryPersonA")
  anniversariesAsB WeddingAnniversary[] @relation("AnniversaryPersonB")
}

/// Wedding anniversary linking two existing individuals (date + notes only).
model WeddingAnniversary {
  id              Int       @id @default(autoincrement())
  individualAId   Int
  individualBId   Int
  anniversaryDate DateTime
  notes           String?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  individualA ChurchIndividual @relation("AnniversaryPersonA", fields: [individualAId], references: [id], onDelete: Restrict)
  individualB ChurchIndividual @relation("AnniversaryPersonB", fields: [individualBId], references: [id], onDelete: Restrict)

  @@index([individualAId])
  @@index([individualBId])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  bodyHtml  String
  weekOf    DateTime
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sermon {
  id        Int       @id @default(autoincrement())
  title     String
  speaker   String
  date      DateTime
  dateOnly  DateTime
  link      String
  status    String    @default("published")
  tagsJson  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ratings SermonRating[]

  @@unique([dateOnly])
}

/// One row per browser/client per sermon (clientId from localStorage). Stars 1–5.
model SermonRating {
  id        Int      @id @default(autoincrement())
  sermonId  Int
  clientId  String
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sermon Sermon @relation(fields: [sermonId], references: [id], onDelete: Cascade)

  @@unique([sermonId, clientId])
  @@index([sermonId])
}

model ProcessDoc {
  id          Int @id @default(autoincrement())
  title       String
  ownerUserId Int
  contentHtml String
  /// public = visible without login; steward = logged-in users only (on /processes)
  audience    String              @default("public")
  version     Int                 @default(1)
  status      String              @default("draft")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  attachments ProcessAttachment[]

  @@index([audience])
}

/// Excel / Word files linked to a process document (download from admin and public views).
model ProcessAttachment {
  id           Int        @id @default(autoincrement())
  processDocId Int
  fileName     String
  storedPath   String
  mimeType     String?
  byteSize     Int?
  createdAt    DateTime   @default(now())
  processDoc   ProcessDoc @relation(fields: [processDocId], references: [id], onDelete: Cascade)

  @@index([processDocId])
}

model Booking {
  id            Int      @id @default(autoincrement())
  bookingRef    String   @unique
  hall          String
  date          DateTime
  startTime     String
  endTime       String
  purpose       String
  requesterName String
  email         String
  phone         String
  status        String   @default("REQUESTED")
  paymentRef    String?
  amount        Float?
  slipUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Singleton row (id = 1): hall hire price per 30-minute block.
model HallBookingSettings {
  id               Int      @id
  ratePer30Minutes Float    @default(0)
  updatedAt        DateTime @updatedAt
}

/// Singleton (id = 1): live church bank details for booking payment instructions (after dual approval).
model ChurchBankAccount {
  id            Int      @id
  accountNumber String
  accountName   String
  bankName      String
  branch        String
  updatedAt     DateTime @updatedAt
}

/// Pending bank detail change; after one approval, values are copied to ChurchBankAccount (id 1).
model ChurchBankAccountProposal {
  id            Int      @id @default(autoincrement())
  accountNumber String
  accountName   String
  bankName      String
  branch        String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
}

model MedicalItem {
  id                Int           @id @default(autoincrement())
  name              String
  quantityTotal     Int
  quantityAvailable Int
  notes             String?
  loans             MedicalLoan[]
}

model MedicalLoan {
  id                Int       @id @default(autoincrement())
  itemId            Int
  givenTo           String
  givenByUserId     Int
  requestDate       DateTime  @default(now())
  approvedByAdminId Int?
  approvedAt        DateTime?
  issuedAt          DateTime?
  dueDate           DateTime?
  returned          Boolean   @default(false)
  returnedAt        DateTime?
  conditionOnReturn String?

  item MedicalItem @relation(fields: [itemId], references: [id])
}

model Upload {
  id          Int      @id @default(autoincrement())
  ownerUserId Int
  path        String
  fileName    String
  mimeType    String
  sizeBytes   Int
  checksum    String?
  createdAt   DateTime @default(now())
}
